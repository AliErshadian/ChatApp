NODE_ENV=development
PORT=3000
HOST=127.0.0.1
DATABASE_URL=postgresql://chatapp:chatapp_secret@localhost:5432/chatapp
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
# Optional during rotation: keep the previous access secret for one JWT_ACCESS_EXPIRES_IN window
# JWT_ACCESS_SECRET_PREVIOUS=
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated allowlist (no "*" when credentials are enabled)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ORIGIN=*
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# debug / info / warn / error
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Websocket rate limits (token bucket). Optional; defaults are safe.
WS_RATE_LIMIT_MESSAGE_SEND_CAPACITY=15
WS_RATE_LIMIT_MESSAGE_SEND_REFILL_PER_SEC=0.5
WS_RATE_LIMIT_TYPING_CAPACITY=6
WS_RATE_LIMIT_TYPING_REFILL_PER_SEC=1.5

# S3-compatible object storage (MinIO local defaults)
S3_ENDPOINT=127.0.0.1
S3_PORT=9000
S3_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_AVATARS=avatars
S3_BUCKET_ATTACHMENTS=attachments
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_VIDEOS=videos
S3_BUCKET_VOICE=voice
S3_BUCKET_BACKUPS=backups
S3_PRESIGNED_URL_EXPIRES_SECONDS=120
STORAGE_MAX_AVATAR_MB=5
STORAGE_MAX_IMAGE_MB=20
STORAGE_MAX_DOCUMENT_MB=100
STORAGE_MAX_VIDEO_MB=500
STORAGE_MAX_VOICE_MB=50

# Encrypts LDAP bind password at rest (openssl rand -hex 32). Optional in development.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DIRECTORY_ENCRYPTION_KEY=

# WebRTC voice calls (1:1 DMs only; requires WebSocket — not SSE)
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Optional TURN for restrictive NAT/firewalls:
# TURN_URL=turn:localhost:3478
# TURN_USERNAME=chatapp
# TURN_PASSWORD=change-me

# Production requirements (validated at startup when NODE_ENV=production):
# - REDIS_URL must be set (redis:// or rediss://)
# - DATABASE_URL must be PostgreSQL with a strong non-default password
# - JWT_ACCESS_SECRET and JWT_REFRESH_SECRET: >= 32 chars, random, different, not placeholders
# - JWT_ACCESS_SECRET_PREVIOUS: optional grace-period secret during access-token rotation
# - CORS_ORIGIN: explicit comma-separated http(s) origins (never "*")
# - LOG_LEVEL: info, warn, error, or fatal
# Generate secrets: npm run generate:secrets --prefix backend
# Validate before deploy: npm run build --prefix backend && NODE_ENV=production npm run validate:env --prefix backend
