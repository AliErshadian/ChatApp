NODE_ENV=development
PORT=3000
HOST=127.0.0.1
DATABASE_URL=postgresql://chatapp:chatapp_secret@localhost:5432/chatapp
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated allowlist (no "*" when credentials are enabled)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ORIGIN=*
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# debug / info / warn / error
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Websocket rate limits (token bucket). Optional; defaults are safe.
WS_RATE_LIMIT_MESSAGE_SEND_CAPACITY=15
WS_RATE_LIMIT_MESSAGE_SEND_REFILL_PER_SEC=0.5
WS_RATE_LIMIT_TYPING_CAPACITY=6
WS_RATE_LIMIT_TYPING_REFILL_PER_SEC=1.5

# Production requirements (validated at startup when NODE_ENV=production):
# - REDIS_URL must be set (redis:// or rediss://)
# - DATABASE_URL must be PostgreSQL with a strong non-default password
# - JWT_ACCESS_SECRET and JWT_REFRESH_SECRET: >= 32 chars, random, different, not placeholders
# - CORS_ORIGIN: explicit comma-separated http(s) origins (never "*")
# - LOG_LEVEL: info, warn, error, or fatal
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Validate before deploy: npm run build && NODE_ENV=production npm run validate:env
