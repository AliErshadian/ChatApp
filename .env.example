# Copy to .env for local/docker overrides
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
# In development, private LAN origins (e.g. http://192.168.x.x:5173) are allowed automatically.
# For production, list every UI origin explicitly (no "*").
CORS_ORIGIN=http://localhost:5173
